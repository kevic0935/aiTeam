# Vite Frontend Environment Variables (Local Development)
# Duplicate this file to `.env` or `.env.local` and fill in your Firebase configuration if you want to use Real-time Sync.
# If these variables are empty, the app will gracefully fall back to local in-memory synchronization.

VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_DATABASE_URL=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""
